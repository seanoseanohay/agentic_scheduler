# ─────────────────────────────────────────────────────────────────────────────
# OneShot Environment Variable Contract
# Copy to .env.local for local development. Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime environment ───────────────────────────────────────────────────────
NODE_ENV=development

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://oneshot:oneshot@localhost:5432/oneshot_dev

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API service ───────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0

# Auth / JWT secret (HS256 for local dev — replaced by managed identity in Azure)
JWT_SECRET=local-dev-secret-replace-in-production

# ── Web / Next.js ─────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=local-dev-nextauth-secret-replace-in-production

# Azure Entra ID (stub values for local dev; real values in Azure Key Vault)
AZURE_AD_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_AD_CLIENT_SECRET=placeholder
AZURE_AD_TENANT_ID=00000000-0000-0000-0000-000000000000

# ── FSP Integration ───────────────────────────────────────────────────────────
# Set to "mock" for local dev; "live" requires FSP credentials
FSP_MODE=mock
FSP_BASE_URL=https://api.flightschedulepro.com
FSP_API_KEY=placeholder

# ── Notifications ─────────────────────────────────────────────────────────────
# ACS connection string (stub for local dev)
ACS_CONNECTION_STRING=endpoint=https://placeholder.communication.azure.com/;accesskey=placeholder

# Optional Twilio fallback
TWILIO_ACCOUNT_SID=placeholder
TWILIO_AUTH_TOKEN=placeholder
TWILIO_FROM_NUMBER=+10000000000

# ── Azure (Production / Phase 1+) ─────────────────────────────────────────────
AZURE_KEY_VAULT_URL=https://placeholder.vault.azure.net/
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=00000000-0000-0000-0000-000000000000

# ── Feature flags ─────────────────────────────────────────────────────────────
# Comma-separated tenant IDs that have each workflow enabled (empty = disabled for all)
FF_WAITLIST_TENANTS=
FF_CANCELLATION_TENANTS=
FF_DISCOVERY_TENANTS=
FF_NEXT_LESSON_TENANTS=

# ── Polling ───────────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=30
